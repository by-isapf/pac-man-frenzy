# Porta do servidor HTTP/WebSocket
PORT=3000

# Região AWS onde a fila SQS foi criada
AWS_REGION=us-east-1

# URL completa da fila SQS (ex: https://sqs.us-east-1.amazonaws.com/123456789012/pacman-events)
SQS_QUEUE_URL=

# Credenciais AWS — em produção use uma IAM Role na EC2 e DEIXE EM BRANCO aqui.
# Se não estiver rodando em EC2 com role, preencha:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Origem permitida no CORS (use * para liberar geral em demo acadêmica)
CORS_ORIGIN=*
